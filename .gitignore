.env
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
build
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Capacitor / native builds ────────────────────────────────
# The native project folders themselves should be committed (they
# contain signing config, app icons, etc.), but build outputs,
# installed pods, and user-specific Xcode data should not.
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captured/
android/app/release/
android/.externalNativeBuild/
android/.cxx/

ios/App/build/
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/DerivedData/
ios/App/output/

# Capacitor generates this on sync — don't commit device-specific paths
.capacitor/
